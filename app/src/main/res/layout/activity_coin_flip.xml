<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen animated coin flip overlay -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000010">

    <!-- Card container centered on screen -->
    <LinearLayout
        android:id="@+id/overlayCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Title -->
        <TextView
            android:id="@+id/overlayTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COIN FLIP"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFC400"
            android:letterSpacing="0.25"
            android:fontFamily="@font/cinzel"
            android:alpha="0"
            android:layout_marginBottom="32dp" />

        <!-- Coin image — large and centered -->
        <ImageView
            android:id="@+id/coinFlipImage"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:src="@drawable/coin_heads"
            android:scaleType="fitCenter"
            android:contentDescription="@string/coin_description" />

        <!-- Result text — fades in after flip -->
        <TextView
            android:id="@+id/coinFlipResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text=""
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFC400"
            android:letterSpacing="0.15"
            android:fontFamily="@font/cinzel"
            android:alpha="0" />

        <!-- Subtitle hint -->
        <TextView
            android:id="@+id/overlayHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text=""
            android:textSize="13sp"
            android:textColor="#66F0EAD6"
            android:letterSpacing="0.1"
            android:alpha="0" />

    </LinearLayout>

</FrameLayout>
