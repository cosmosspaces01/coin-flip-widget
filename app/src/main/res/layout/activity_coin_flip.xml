<?xml version="1.0" encoding="utf-8"?>
<!-- Transparent overlay layout for widget-launched coin flip -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#88000000"
    android:gravity="center">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@drawable/overlay_background">

        <ImageView
            android:id="@+id/coinFlipImage"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/coin_heads"
            android:scaleType="fitCenter"
            android:contentDescription="@string/coin_description" />

        <TextView
            android:id="@+id/coinFlipResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text=""
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/gold_400"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

</FrameLayout>
