<?xml version="1.0" encoding="utf-8"?>
<!-- Transparent overlay layout for widget-launched coin flip -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#AA000000"
    android:gravity="center">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingTop="36dp"
        android:paddingBottom="36dp"
        android:background="@drawable/overlay_background"
        android:elevation="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🪙 Coin Flip"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/gold_400"
            android:layout_marginBottom="20dp" />

        <!-- Coin image (animated) -->
        <ImageView
            android:id="@+id/coinFlipImage"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/coin_heads"
            android:scaleType="fitCenter"
            android:contentDescription="@string/coin_description" />

        <!-- Result text (fades in after flip) -->
        <TextView
            android:id="@+id/coinFlipResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text=""
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/gold_400"
            android:fontFamily="sans-serif-medium"
            android:alpha="0" />

    </LinearLayout>

</FrameLayout>
