<?xml version="1.0" encoding="utf-8"?>
<!-- Widget Layout: Coin Flip Home Screen Widget -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Coin Image -->
    <ImageView
        android:id="@+id/coinImage"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/coin_heads"
        android:scaleType="fitCenter"
        android:contentDescription="@string/coin_description" />

    <!-- Result Text -->
    <TextView
        android:id="@+id/resultText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/tap_to_flip"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif-medium" />

    <!-- Stats Row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/headsCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👑 0"
            android:textSize="12sp"
            android:textColor="@color/gold_400"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tailsCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🦅 0"
            android:textSize="12sp"
            android:textColor="@color/blue_glow" />
    </LinearLayout>

    <!-- Streak Text -->
    <TextView
        android:id="@+id/streakText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="11sp"
        android:textColor="@color/gold_300"
        android:text="" />

    <!-- Open App Button -->
    <TextView
        android:id="@+id/openAppButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/open_app"
        android:textSize="10sp"
        android:textColor="@color/text_muted"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:padding="4dp" />

</LinearLayout>
